---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import posts from "../../../data/blog/posts.json";
import { Image } from "astro:assets";
const images = import.meta.glob<{ default: ImageMetadata }>("../../assets/images/blog/*.{jpeg,jpg,png,gif}");

export function getStaticPaths() {
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(post.image || "/hero-salon.png", Astro.site);

const blogImagePath = post.image ? post.image.replace("/images/blog/", "../../assets/images/blog/") : null;
const blogImageFunc = blogImagePath ? images[blogImagePath] : null;
const blogImage = blogImageFunc ? blogImageFunc() : null;

const authorData = {
  name: post.author,
  title: post.author.includes("Ganapathy") ? "Marketing & Growth Strategist" : "Vantha Vettuvom Team",
  linkedin: post.author.includes("Ganapathy") ? "https://www.linkedin.com/in/ganapathy2002" : "https://www.vanthavettuvom.com/"
};

const wordCount = post.content.replace(/<[^>]*>/g, '').split(/\s+/).filter(Boolean).length;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://www.vanthavettuvom.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://www.vanthavettuvom.com/blog"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.title,
      "item": Astro.url.href
    }
  ]
};

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": socialImageURL.href,
  "wordCount": wordCount,
  "datePublished": post.date,
  "dateModified": post.modifiedDate || post.date,
  "author": {
    "@type": "Person",
    "name": authorData.name,
    "jobTitle": authorData.title,
    "url": authorData.linkedin
  },
  "publisher": {
    "@id": "https://www.vanthavettuvom.com/#organization"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  },
  ...(post.location ? {
    "contentLocation": {
      "@type": "Place",
      "name": post.location
    }
  } : {})
};

const listSchema = post.listItems ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": post.title,
  "itemListElement": post.listItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "description": item.description
  }))
} : null;

const faqSchema = post.faqs ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

const postKeywords = `${post.title.toLowerCase().replace(/[^a-zA-Z0-9 ]/g, '').split(' ').filter(w => w.length > 3).join(', ')}, ${post.location ? post.location.toLowerCase() + ', ' : ''}${post.author.toLowerCase()}, vantha vettuvom, salon franchise tamil nadu`;
---

<Layout 
    title={post.title} 
    description={post.excerpt} 
    image={post.image}
    type="article"
    keywords={postKeywords}
    additionalSchema={[blogSchema, breadcrumbSchema, listSchema, faqSchema].filter(Boolean)}
>
    <nav
        class="absolute top-0 left-0 w-full z-50 py-6 px-4 lg:px-12 flex justify-between items-center bg-gray-950/80 backdrop-blur-md border-b border-white/5"
    >
        <a
            href="/"
            class="block w-32 md:w-40 opacity-90 hover:opacity-100 transition duration-300 relative group"
            aria-label="Home"
            title="Go to Home"
        >
            <span class="absolute -inset-1 bg-linear-to-r from-gold-500 to-gold-700 rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></span>
            <Image
                src="/logo1.png"
                alt="Vantha Vettuvom Logo"
                class="w-full h-auto relative"
                width={160}
                height={104}
            />
        </a>
        <a
            href="/blog"
            class="text-gray-400 hover:text-white transition text-sm uppercase tracking-widest font-medium"
            aria-label="Back to Blog"
            title="Return to Blog Listing"
            >Back to Blog</a
        >
    </nav>

    <article class="bg-gray-950 min-h-screen pt-32 pb-24 px-4 md:px-12">
        <div class="max-w-4xl mx-auto">
            <header class="mb-12 text-center">
                <!-- Breadcrumbs -->
                <nav class="flex items-center justify-center gap-2 text-gray-500 text-xs md:text-sm mb-12 uppercase tracking-[0.15em] font-medium">
                    <a href="/" class="hover:text-gold-400 transition-colors duration-300" title="Home">Home</a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                    <a href="/blog" class="hover:text-gold-400 transition-colors duration-300" title="Blog">Blog</a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                    <span class="text-gold-500/80 truncate max-w-[150px] md:max-w-none">{post.title}</span>
                </nav>
                <div
                    class="inline-block px-4 py-1 rounded-full bg-gold-900/20 border border-gold-500/20 mb-6"
                >
                    <span
                        class="text-gold-500 font-bold tracking-[0.2em] uppercase text-xs"
                        >{post.date}</span
                    >
                </div>
                <h1
                    class="text-3xl md:text-5xl lg:text-6xl font-display font-medium text-white mt-2 leading-tight max-w-5xl mx-auto"
                >
                    {post.title}
                </h1>

                {post.location && (
                    <div class="flex items-center justify-center gap-2 mt-4 text-gold-500/90 text-sm uppercase tracking-widest font-semibold">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span>{post.location}</span>
                    </div>
                )}
                <div class="flex flex-col items-center justify-center gap-2 mt-6">
                    <p class="text-white font-medium text-lg">
                        By {authorData.name}
                    </p>
                    <p class="text-gold-500/80 text-sm uppercase tracking-[0.2em] font-medium">
                        {authorData.title}
                    </p>
                    <a 
                        href={authorData.linkedin} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="text-gray-500 hover:text-white transition flex items-center gap-1.5 text-xs mt-1"
                        aria-label={`Visit ${authorData.name}'s LinkedIn profile`}
                        title={`Connect with ${authorData.name} on LinkedIn`}
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                        LinkedIn Profile
                    </a>
                </div>
            </header>

            <div
                class="w-full h-[400px] md:h-[500px] bg-gray-900 rounded-3xl border border-white/5 mb-16 relative overflow-hidden group shadow-2xl"
            >
                {blogImage ? (
                    <Image 
                        src={blogImage} 
                        alt={post.title} 
                        class="w-full h-full object-cover transition duration-700 group-hover:scale-105"
                        width={1200}
                        quality="high"
                    />
                ) : (
                    <div class="absolute inset-0 bg-linear-to-br from-gray-800 to-gray-900 opacity-50 flex items-center justify-center">
                        <span class="text-7xl font-display text-white/5 group-hover:text-gold-500/10 transition duration-500 transform group-hover:scale-110">VV</span>
                    </div>
                )}
                <div
                    class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/20 to-transparent opacity-60 z-10"
                >
                </div>
            </div>

            <div
                class="prose-content text-gray-300 text-lg leading-loose font-light space-y-6"
            >
                <Fragment set:html={post.content} />
            </div>

            {post.faqs && post.faqs.length > 0 && (
                <div class="mt-16 pt-16 border-t border-white/10">
                    <h2 class="text-3xl font-display text-white mb-10 text-center">Frequently Asked <span class="text-gold-400">Questions</span></h2>
                    <div class="space-y-6 max-w-3xl mx-auto">
                        {post.faqs.map((faq) => (
                            <div class="bg-white/5 rounded-2xl p-6 md:p-8 border border-white/5 hover:border-gold-500/20 transition duration-300">
                                <h3 class="text-white font-semibold text-lg mb-4 flex gap-4">
                                    <span class="text-gold-500">Q.</span> {faq.question}
                                </h3>
                                <p class="text-gray-400 leading-relaxed pl-8 relative">
                                    <span class="absolute left-0 top-0 text-gold-500/40 font-bold">A.</span>
                                    {faq.answer}
                                </p>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            <div class="mt-20 pt-12 border-t border-white/10 text-center">
                <h3 class="text-3xl font-display text-white mb-6">
                    Start Your Franchise Journey
                </h3>
                <p class="text-gray-400 mb-8 max-w-xl mx-auto">
                    Join the Vantha Vettuvom family and own a profitable
                    business in the booming salon industry.
                </p>
                <a
                    href="/#inquiry-form"
                    class="inline-block bg-linear-to-r from-gold-500 to-gold-700 hover:from-gold-400 hover:to-gold-600 text-white font-medium tracking-wide py-4 px-12 rounded-full transition duration-300 shadow-xl shadow-gold-900/20 hover:scale-105 transform"
                    aria-label="Enquire about a franchise partnership"
                    title="Send Franchise Inquiry"
                >
                    Enquire Now
                </a>
            </div>
        </div>
    </article>

    <footer class="bg-black py-16 border-t border-white/5 text-center px-4">
        <div class="max-w-4xl mx-auto">
            <a
                href="https://www.vanthavettuvom.com/"
                class="inline-block w-40 mb-8 opacity-50 hover:opacity-100 transition duration-300"
                aria-label="Home"
                title="Go to Home"
            >
                <Image
                    src="/logo1.png"
                    alt="Vantha Vettuvom Logo"
                    class="w-full h-auto"
                    width={160}
                    height={104}
                />
            </a>
            <div class="flex flex-wrap justify-center gap-6 mb-8 text-xs uppercase tracking-widest font-medium">
                <a href="/privacy-policy" class="text-gray-500 hover:text-gold-400 transition" aria-label="Privacy Policy" title="Read our Privacy Policy">Privacy Policy</a>
                <a href="/terms-and-conditions" class="text-gray-500 hover:text-gold-400 transition" aria-label="Terms and Conditions" title="Read our Terms and Conditions">Terms & Conditions</a>
            </div>
            <p class="text-gray-600 text-xs tracking-wider uppercase">
                © {new Date().getFullYear()} <a href="https://www.vanthavettuvom.com/" class="hover:text-gold-400 transition-colors duration-300" aria-label="Visit Vantha Vettuvom Website" title="Visit Vantha Vettuvom Official Website">VANTHA VETTUVOM SALON</a>. ALL RIGHTS RESERVED.
            </p>
        </div>
    </footer>
</Layout>

<style is:global>
    /* Custom styles for content injected via set:html */
    .prose-content p {
        margin-bottom: 1.5rem;
    }
    .prose-content a {
        color: #d6a843;
        text-decoration: underline;
        text-underline-offset: 4px;
    }
    .prose-content strong {
        color: #fff;
        font-weight: 600;
    }
</style>
