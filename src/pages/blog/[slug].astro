---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import posts from "../../../data/blog/posts.json";

export function getStaticPaths() {
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(post.image || "/hero-salon.png", Astro.site);

const authorData = {
  name: post.author,
  title: post.author === "Ganapathy M.B.A" ? "Marketing Analyst" : "Vantha Vettuvom Team",
  linkedin: post.author === "Ganapathy M.B.A" ? "https://www.linkedin.com/in/ganapathy2002/" : "https://vanthavettuvom.com/"
};

const blogSchema = [
  {
    "@type": "BlogPosting",
    "@id": `${canonicalURL}#article`,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalURL
    },
    "headline": post.title,
    "description": post.excerpt,
    "image": socialImageURL,
    "datePublished": post.date,
    "dateModified": post.modifiedDate || post.date,
    "author": {
      "@type": "Person",
      "name": authorData.name,
      "jobTitle": authorData.title,
      "url": authorData.linkedin
    },
    "publisher": {
      "@id": "https://vanthavettuvom.com/#organization"
    }
  }
];

const postKeywords = `${post.title.toLowerCase().split(' ').join(', ')}, whatsapp api india, cheapest whatsapp api, whatsapp business api pricing, ${post.author.toLowerCase()}`;
---

<Layout 
    title={post.title} 
    description={post.excerpt} 
    image={post.image}
    keywords={postKeywords}
    additionalSchema={blogSchema}
>
    <article class="bg-gray-950 min-h-screen pt-16 pb-24 px-6 md:px-12">
        <div class="max-w-4xl mx-auto">
            <header class="mb-12 text-center">
                <div
                    class="inline-block px-4 py-1 rounded-full bg-gold-900/20 border border-gold-500/20 mb-6"
                >
                    <span
                        class="text-gold-500 font-bold tracking-[0.2em] uppercase text-xs"
                        >{post.date}</span
                    >
                </div>
                <h1
                    class="text-3xl md:text-5xl lg:text-6xl font-display font-medium text-white mt-2 leading-tight max-w-5xl mx-auto"
                >
                    {post.title}
                </h1>
                <div class="flex flex-col items-center justify-center gap-2 mt-6">
                    <p class="text-white font-medium text-lg">
                        By {authorData.name}
                    </p>
                    <p class="text-gold-500/80 text-sm uppercase tracking-[0.2em] font-medium">
                        {authorData.title}
                    </p>
                    <a 
                        href={authorData.linkedin} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="text-gray-500 hover:text-white transition flex items-center gap-1.5 text-xs mt-1"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                        LinkedIn Profile
                    </a>
                </div>
            </header>

            <div
                class="w-full h-[400px] md:h-[500px] bg-gray-900 rounded-3xl border border-white/5 mb-16 relative overflow-hidden group shadow-2xl"
            >
                {post.image ? (
                    <img 
                        src={post.image} 
                        alt={post.title} 
                        class="w-full h-full object-cover transition duration-700 group-hover:scale-105"
                    />
                ) : (
                    <div class="absolute inset-0 bg-gradient-to-br from-gray-800 to-gray-900 opacity-50 flex items-center justify-center">
                        <span class="text-7xl font-display text-white/5 group-hover:text-gold-500/10 transition duration-500 transform group-hover:scale-110">VV</span>
                    </div>
                )}
                <div
                    class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/20 to-transparent opacity-60 z-10"
                >
                </div>
            </div>

            <div
                class="prose-content text-gray-300 text-lg leading-loose font-light space-y-6"
            >
                <Fragment set:html={post.content} />
            </div>

            <div class="mt-20 pt-12 border-t border-white/10 text-center">
                <h3 class="text-3xl font-display text-white mb-6">
                    Start Your Franchise Journey
                </h3>
                <p class="text-gray-400 mb-8 max-w-xl mx-auto">
                    Join the Vantha Vettuvom family and own a profitable
                    business in the booming salon industry.
                </p>
                <a
                    href="/#inquiry-form"
                    class="inline-block bg-gradient-to-r from-gold-500 to-gold-700 hover:from-gold-400 hover:to-gold-600 text-white font-medium tracking-wide py-4 px-12 rounded-full transition duration-300 shadow-xl shadow-gold-900/20 hover:scale-105 transform"
                >
                    Enquire Now
                </a>
            </div>
        </div>
    </article>

    <footer class="bg-black py-16 border-t border-white/5 text-center">
        <a
            href="https://vanthavettuvom.com/"
            class="inline-block w-40 mb-8 grayscale brightness-0 invert opacity-50 hover:opacity-100 transition duration-300"
        >
            <img
                src="/logo1.png"
                alt="Vantha Vettuvom Logo"
                class="w-full h-auto"
            />
        </a>
        <p class="text-gray-600 text-xs tracking-wider">
            © {new Date().getFullYear()} VANTHA VETTUVOM SALON. ALL RIGHTS RESERVED.
        </p>
    </footer>
</Layout>

<style is:global>
    /* Custom styles for content injected via set:html */
    .prose-content p {
        margin-bottom: 1.5rem;
    }
    .prose-content a {
        color: #d6a843;
        text-decoration: underline;
        text-underline-offset: 4px;
    }
    .prose-content strong {
        color: #fff;
        font-weight: 600;
    }
</style>
