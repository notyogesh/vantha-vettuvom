---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import posts from "../../data/blog/posts.json";
import heroImage from "../assets/images/hero-salon.png";

const images = import.meta.glob<{ default: ImageMetadata }>("../assets/images/blog/*.{jpeg,jpg,png,gif}");

const recentPosts = posts
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
    .slice(0, 3);

const homeFAQs = [
    {
        question: "What is the investment required for a Vantha Vettuvom franchise?",
        answer: "The initial investment for a Vantha Vettuvom franchise typically starts from ₹7 Lakhs. This includes franchise fees, interior setup, initial product stock, and equipment. The exact cost varies depending on the salon model and location size."
    },
    {
        question: "Does Vantha Vettuvom provide staff recruitment and training?",
        answer: "Yes, we provide end-to-end support for staff recruitment and training. We help you hire skilled stylists and provide 15 days of intensive training to ensure they meet our ultra-luxury service standards."
    },
    {
        question: "How long does it take to set up a new salon?",
        answer: "Typically, it takes 45 to 60 days to launch a new Vantha Vettuvom salon from the date of site finalization. This includes interior design, civil works, equipment installation, and staff training."
    },
    {
        question: "Is it better to start from scratch or take a franchise?",
        answer: "Starting from scratch gives you full creative control, but a franchise like Vantha Vettuvom provides a proven business model, recruitment support, and a name that guarantees customers from day one."
    },
    {
        question: "Is there a monthly royalty fee?",
        answer: "Yes, we follow a fixed monthly royalty model of ₹10,000 + GST. Unlike other brands, we do not take a percentage of your revenue, allowing you to keep all the profits as your business grows."
    },
    {
        question: "How many salons does Vantha Vettuvom currently have?",
        answer: "Vantha Vettuvom is the largest salon chain in Tamil Nadu with over 600+ successful outlets across the state, making us the most trusted and recognized brand in the industry."
    }
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": homeFAQs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
        }
    }))
};
const testimonials = [
    { name: "Ganesan", city: "Chennai", text: "Managing a salon was always my dream, but Akhil sir and the team made it a reality in Chennai. The training was so detailed, even with zero industry experience, I'm now running a top-performing branch." },
    { name: "Suriya", city: "Coimbatore", text: "Value for money in every sense. The ₹10k fixed royalty is such a relief compared to other brands taking up to 10% of revenue. My branch in Coimbatore is finally profitable!" },
    { name: "Vijayalakshmi", city: "Madurai", text: "The interiors are premium, and customers in Madurai are absolutely loving the ultra-luxury vibe. Vantha Vettuvom is truly the pride of Tamil Nadu!" },
    { name: "Saravanan", city: "Salem", text: "I started my journey with one branch in Salem, and the response was so overwhelming I'm already looking for a second location. The support is beyond words." },
    { name: "Meenakshi", city: "Trichy", text: "Professional staffing. I didn't have to worry about recruiting and training as the brand took full care of it for my Trichy outlet." },
    { name: "Prabhakaran", city: "Vellore", text: "The naming is so catchy! Customers in Vellore find the brand name very relatable. Best decision for my first business venture." },
    { name: "Anbarasu", city: "Erode", text: "Luxury services at accessible pricing is our USP. Our Erode clients keep coming back for the specialized treatments." },
    { name: "Kavitha", city: "Tirunelveli", text: "Running a salon in Tirunelveli was once a challenge, but with Vantha Vettuvom's marketing support, we're booked out weeks in advance." },
    { name: "Muthu", city: "Thanjavur", text: "Transparent commercials. No hidden costs. Everything was exactly as discussed in the initial meeting for my Thanjavur salon." },
    { name: "Dhanalakshmi", city: "Hosur", text: "The ROI of this franchise model is incredible. My Hosur salon reached break-even much faster than I expected." },
    { name: "Selvaraj", city: "Karur", text: "Ultra-luxury standards in a small town like Karur? People didn't believe it initially, but the brand made it happen. Totally worth it." },
    { name: "Sangeetha", city: "Nagercoil", text: "Elite customer service. My staff was trained for 15 days, and now they handle every client with perfection at our Nagercoil branch." },
    { name: "Ramasamy", city: "Dindigul", text: "Vantha Vettuvom's brand power is enough. I barely spent on advertising for my Dindigul branch, customers just walked in on day one." },
    { name: "Indumathi", city: "Pudukkottai", text: "Even in Pudukkottai, we are delivering a metropolitan-level salon experience. This brand is truly democratizing luxury across the state." },
    { name: "Senthil", city: "Kumbakonam", text: "A sustainable legacy. I'm building something I can pass down to my children. Thank you team for the opportunity in Kumbakonam." },
    { name: "Rajalakshmi", city: "Sivakasi", text: "I switched from an independent salon to this franchise in Sivakasi, and my revenue has doubled within 4 months. The system works!" },
    { name: "Arunchalam", city: "Virudhunagar", text: "The marketing strategies for Virudhunagar were very specific to our local audience. The team knows what they're doing." },
    { name: "Kalpana", city: "Pollachi", text: "Being the first Vantha Vettuvom in Pollachi, we've set a new standard for hair and skin care in our region. Highly recommend it." },
    { name: "Murugan", city: "Dharmapuri", text: "The financial model is transparent and lucrative. My Dharmapuri branch is proof that luxury salon business can thrive anywhere." },
    { name: "Amudha", city: "Tuticorin", text: "More than just a business, it's a family. The support I received during the launch in Tuticorin was heartfelt and consistent." }
];
---


<Layout
  title="Vantha Vettuvom: #1 Luxury Salon Franchise in Tamil Nadu (600+ Salons)"
  description="Join the fastest growing luxury salon chain in Tamil Nadu. Vantha Vettuvom franchise opportunity offers high ROI and expert support."
  additionalSchema={[faqSchema]}
>
  <main class="relative font-body text-gray-200">
    <!-- Navbar -->
     
    <nav
      class="absolute top-0 left-0 w-full z-50 py-6 px-6 lg:px-12 flex justify-between items-center"
    >
      <a
        href="/"
        class="block w-40 md:w-52 opacity-90 hover:opacity-100 transition duration-300"
        aria-label="Home"
        title="Go to Home"
      >
        <Image
          src="/logo1.png"
          alt="Vantha Vettuvom Logo"
          class="w-full h-auto drop-shadow-md"
          width={210}
          height={136}
          quality="high"
        />
      </a>
    </nav>
    <!-- Hero Section -->
    <section
      class="relative min-h-screen flex items-center justify-center overflow-hidden"
    >
      <!-- Background Image -->
      <div class="absolute inset-0 z-0 select-none">
        <Image
          src={heroImage}
          alt="Luxury Salon Interior - Vantha Vettuvom Franchise"
          class="w-full h-full object-cover opacity-60"
          draggable="false"
          width={1920}
          height={1080}
          quality="max"
        />
        <!-- Overlay for better text readability -->
        <div
          class="absolute inset-0 bg-linear-to-r from-gray-950 via-gray-950/80 to-transparent"
        >
        </div>
        <div
          class="absolute inset-0 bg-linear-to-t from-gray-950 via-transparent to-transparent"
        >
        </div>
      </div>

      <div
        class="container mx-auto px-6 lg:px-12 relative z-10 grid lg:grid-cols-12 gap-12 items-center pt-40 lg:pt-42"
      >
        <!-- Text Content -->
        <div
          class="lg:col-span-7 space-y-8 animate-fade-in text-center lg:text-left"
        >
          <div
            class="inline-block px-4 py-1.5 rounded-full border border-gold-500/30 bg-gold-900/20 backdrop-blur-md"
          >
            <span
              class="text-gold-300 font-medium tracking-[0.2em] uppercase text-xs"
              >Premium Franchise Opportunity</span
            >
          </div>

          <h1
            class="text-4xl md:text-6xl xl:text-7xl font-display font-medium leading-none tracking-tight text-white/90"
          >
            <span
              class="text-transparent bg-clip-text bg-linear-to-r from-gold-200 via-gold-400 to-gold-600 drop-shadow-xl"
              >Vantha Vettuvom</span
            >
            <br />
            Salon Franchise <br class="hidden lg:block" /> Opportunity in India
          </h1>

          <div
            class="flex flex-wrap items-center gap-4 text-gold-400 font-medium tracking-wide text-sm md:text-base justify-center lg:justify-start"
          >
            <span class="flex items-center gap-2"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
              > 600+ Salons
            </span>
            <span class="w-1.5 h-1.5 rounded-full bg-gold-600 hidden md:block"></span>
            <span> #1 in Tamil Nadu</span>
          </div>

          <p
            class="text-gray-300 text-base md:text-lg max-w-xl mx-auto lg:mx-0 leading-relaxed font-light"
          >
            Partner with <span class="font-medium text-white"
              >Vantha Vettuvom</span
            >, the most trusted franchise brand in Tamil Nadu with over <span
              class="text-gold-400 font-medium">600+ locations</span
            >. Own a masterpiece, not just a salon. We provide a proven business
            ecosystem, elite staffing, and a brand that defines opulence.
          </p>

          <div class="hidden lg:flex gap-6 pt-4">
            <a
              href="#inquiry-form"
              class="bg-linear-to-r from-gold-500 to-gold-700 hover:from-gold-400 hover:to-gold-600 text-white font-medium tracking-wide py-4 px-10 rounded-full transition duration-500 transform hover:scale-105 shadow-[0_0_30px_rgba(204,143,42,0.3)]"
              aria-label="Become a Vantha Vettuvom franchise partner"
              title="Apply for Vantha Vettuvom Franchise"
            >
              Become a Partner
            </a>
            <a
              href="#benefits"
              class="relative group overflow-hidden border border-white/20 hover:border-gold-500/50 text-white font-medium py-4 px-10 rounded-full transition duration-300 backdrop-blur-sm"
              aria-label="Learn more about our franchise benefits"
              title="Explore Franchise Benefits"
            >
              <span
                class="absolute w-0 h-0 transition-all duration-500 ease-out bg-white rounded-full group-hover:w-56 group-hover:h-56 opacity-5"
              ></span>
              Learn More
            </a>
          </div>
        </div>

        <!-- Inquiry Form -->
        <div class="lg:col-span-5 relative">
          <!-- Glow effect behind form -->
          <div
            class="absolute -inset-1 bg-linear-to-r from-gold-500 to-gold-700 rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"
          >
          </div>

          <div
            id="inquiry-form"
            class="relative bg-gray-950/80 backdrop-blur-2xl border border-white/10 px-4 py-8 md:p-10 rounded-3xl shadow-2xl w-full mx-auto"
          >
            <div class="mb-8 text-center lg:text-left">
              <h2 class="text-3xl font-display font-bold text-white mb-2">
                Start Your Journey
              </h2>
              <p class="text-gold-200/80 text-sm">
                Request the official franchise brochure & financial model.
              </p>
            </div>

            <form id="franchiseForm" class="space-y-6">
              <div class="space-y-2">
                <label
                  for="name"
                  class="block text-xs font-semibold text-gold-300 uppercase tracking-wider ml-1"
                  >Full Name</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 focus:outline-none focus:border-gold-500 focus:bg-white/10 transition text-white placeholder-gray-500"
                  placeholder="Name"
                />
              </div>

              <div class="space-y-2">
                <label
                  for="city"
                  class="block text-xs font-semibold text-gold-300 uppercase tracking-wider ml-1"
                  >City / Location</label
                >
                <input
                  type="text"
                  id="city"
                  name="city"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 focus:outline-none focus:border-gold-500 focus:bg-white/10 transition text-white placeholder-gray-600"
                  placeholder="Ex. Chennai"
                />
              </div>
              <div class="space-y-2">
                <label
                  for="phone"
                  class="block text-xs font-semibold text-gold-300 uppercase tracking-wider ml-1"
                  >Phone Number</label
                >
                <div class="relative">
                  <div
                    class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
                  >
                    <span class="text-gray-400 font-medium">+91</span>
                  </div>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    pattern="[0-9]{10}"
                    class="w-full bg-white/5 border border-white/10 rounded-xl pl-14 pr-5 py-4 focus:outline-none focus:border-gold-500 focus:bg-white/10 transition text-white placeholder-gray-500"
                    placeholder="98xxxx xxxxx"
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label
                  for="message"
                  class="block text-xs font-semibold text-gold-300 uppercase tracking-wider ml-1"
                  >Message (Optional)</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="3"
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 focus:outline-none focus:border-gold-500 focus:bg-white/10 transition text-white placeholder-gray-500 resize-none"
                  placeholder="Tell us about your requirements..."
                ></textarea>
              </div>

              <div class="hidden" aria-hidden="true">
                <input
                  type="text"
                  name="address"
                  id="address"
                  tabindex="-1"
                  autocomplete="off"
                />
              </div>

              <button
                type="submit"
                id="submitBtn"
                class="w-full bg-linear-to-r from-gold-500 to-gold-700 hover:from-gold-400 hover:to-gold-600 text-white font-bold py-5 rounded-xl transition duration-300 shadow-lg mt-4 flex items-center justify-center group tracking-wide uppercase text-sm"
                aria-label="Submit your franchise inquiry"
              >
                <span class="group-hover:translate-x-1 transition-transform"
                  >Submit Inquiry</span
                >
              </button>
              <div
                id="formStatus"
                class="contain-content text-center text-sm mt-3 h-6"
              >
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section id="benefits" class="py-32 bg-gray-950 relative overflow-hidden">
      <!-- Decorational blobs -->
      <div
        class="absolute top-0 left-0 w-[500px] h-[500px] bg-gold-600/5 rounded-full blur-[100px] -translate-x-1/2 -translate-y-1/2 pointer-events-none"
      >
      </div>
      <div
        class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-gold-600/5 rounded-full blur-[100px] translate-x-1/2 translate-y-1/2 pointer-events-none"
      >
      </div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-20 space-y-6">
          <span
            class="text-gold-500 font-medium tracking-[0.2em] uppercase text-sm"
            >Why Choose Us</span
          >
          <h2 class="text-4xl md:text-6xl font-display font-medium text-white">
            The <span
              class="bg-gradient-to-r from-gold-300 to-gold-600 text-transparent bg-clip-text"
              >Gold Standard</span>
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto text-lg font-light">
            Join the largest salon network in Tamil Nadu. We don't just set up a
            salon; we build a sustainable legacy with you.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-10">
          <!-- Feature 1 -->
          <div
            class="bg-gray-900/40 px-4 py-8 md:p-10 rounded-2xl border border-white/5 hover:border-gold-500/30 transition duration-500 group"
          >
            <div
              class="w-16 h-16 bg-gradient-to-br from-gold-500 to-gold-700 rounded-full flex items-center justify-center mb-8 shadow-lg shadow-gold-900/20 group-hover:scale-110 transition duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <h3
              class="text-2xl font-display font-medium mb-4 text-white group-hover:text-gold-400 transition"
            >
              Proven ROI
            </h3>
            <p class="text-gray-400 leading-relaxed font-light">
              Our business model is meticulously designed for high margins and
              operational efficiency.
            </p>
          </div>

          <!-- Feature 2 -->
          <div
            class="bg-gray-900/40 p-10 rounded-2xl border border-white/5 hover:border-gold-500/30 transition duration-500 group"
          >
            <div
              class="w-16 h-16 bg-gradient-to-br from-gold-500 to-gold-700 rounded-full flex items-center justify-center mb-8 shadow-lg shadow-gold-900/20 group-hover:scale-110 transition duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-2xl font-display font-medium mb-4 text-white group-hover:text-gold-400 transition"
            >
              Elite Staffing
            </h3>
            <p class="text-gray-400 leading-relaxed font-light">
              Access our academy-trained stylists and continuous education
              programs to ensure premium service.
            </p>
          </div>

          <!-- Feature 3 -->
          <div
            class="bg-gray-900/40 p-10 rounded-2xl border border-white/5 hover:border-gold-500/30 transition duration-500 group"
          >
            <div
              class="w-16 h-16 bg-gradient-to-br from-gold-500 to-gold-700 rounded-full flex items-center justify-center mb-8 shadow-lg shadow-gold-900/20 group-hover:scale-110 transition duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6 3 3 0 000 6v6a3 3 0 100-6 3 3 0 000 6z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-2xl font-display font-medium mb-4 text-white group-hover:text-gold-400 transition"
            >
              Hyper-Growth Marketing
            </h3>
            <p class="text-gray-400 leading-relaxed font-light">
              We handle national branding while empowering you with local
              strategies to dominate your market.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Investment & ROI Section -->
    <section
      class="py-24 bg-gray-950 relative overflow-hidden text-center lg:text-left"
    >
      <!-- Background pattern -->
      <div
        class="absolute inset-0 bg-[url('/logo1.png')] bg-center bg-no-repeat opacity-[0.03] scale-150 grayscale blur-sm pointer-events-none"
      >
      </div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Content -->
          <div class="space-y-8 order-2 lg:order-1">
            <div>
              <span
                class="text-gold-500 font-medium tracking-[0.2em] uppercase text-sm"
                >Financial Model</span
              >
              <h2
                class="text-3xl md:text-5xl font-display font-medium text-white mt-4 leading-tight"
              >
                Smart Investment, <br /><span class="text-gold-400"
                  >Superior Returns</span>
              </h2>
            </div>

            <div class="space-y-6">
              <!-- Point 1 -->
              <div class="flex gap-4">
                <div
                  class="mt-1 w-8 h-8 rounded-full bg-gold-900/30 flex items-center justify-center border border-gold-500/20 shrink-0"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-gold-400"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    ><path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path></svg
                  >
                </div>
                <div>
                  <h4 class="text-xl font-medium text-white">
                    Low Investment Franchise
                  </h4>
                  <p class="text-gray-400 text-sm mt-1">
                    Start your luxury salon journey with an optimized capital
                    requirement designed for accessibility.
                  </p>
                </div>
              </div>

              <!-- Point 2 -->
              <div class="flex gap-4">
                <div
                  class="mt-1 w-8 h-8 rounded-full bg-gold-900/30 flex items-center justify-center border border-gold-500/20 shrink-0"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-gold-400"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path></svg
                  >
                </div>
                <div>
                  <h4 class="text-xl font-medium text-white">
                    Faster Break-Even
                  </h4>
                  <p class="text-gray-400 text-sm mt-1">
                    Our high-efficiency operational model ensures you recover
                    your investment faster than typical premium salons.
                  </p>
                </div>
              </div>

              <!-- Point 3 -->
              <div class="flex gap-4">
                <div
                  class="mt-1 w-8 h-8 rounded-full bg-gold-900/30 flex items-center justify-center border border-gold-500/20 shrink-0"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-gold-400"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path></svg
                  >
                </div>
                <div>
                  <h4 class="text-xl font-medium text-white">
                    Transparent Commercials
                  </h4>
                  <p class="text-gray-400 text-sm mt-1">
